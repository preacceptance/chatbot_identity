rtTag":"able_nothing_explain","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please explain your answer","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None","MinChars":"1"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID177","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID191","SecondaryAttribute":"Please rate the extent to which you agree: I can count on ${lm:\/\/Field\/1}\u00a0when things go wrong.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please rate the extent to which you agree: I can count on <u><strong>${lm:\/\/Field\/1}<\/strong><\/u>&nbsp;when things go wrong.","DefaultChoices":false,"DataExportTag":"support","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.50047125353440147232930712561937980353832244873046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Please rate the extent to which you agree: I can count on ${lm:\/\/Field\/1}\u00a0when things go wrong.","Choices":{"1":{"Display":"&nbsp;"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":8,"Labels":{"3":{"Display":"Strongly disagree"},"7":{"Display":"Strongly agree"}},"QuestionID":"QID191"}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID192","SecondaryAttribute":"Please rate the extent to which you agree: There is a special connection I feel with ...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please rate the extent to which you agree: There is a special connection I feel with <u><strong>${lm:\/\/Field\/1}<\/strong><\/u>&nbsp;when I am in need.","DefaultChoices":false,"DataExportTag":"support_3","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.50047125353440147232930712561937980353832244873046875},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Please rate the extent to which you agree: There is a special connection I feel with ...","Choices":{"1":{"Display":"&nbsp;"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":8,"Labels":{"3":{"Display":"Strongly disagree"},"7":{"Display":"Strongly agree"}},"QuestionID":"QID192"}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID190","SecondaryAttribute":"Please rate the extent to which you agree:\u00a0${lm:\/\/Field\/3}\u00a0really tries to help me.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please rate the extent to which you agree:&nbsp;<strong style=\"text-decoration-line: underline;\">${lm:\/\/Field\/3}<\/strong>&nbsp;really tries to help me.","DefaultChoices":false,"DataExportTag":"support_1","QuestionType":"Slider","Selector":"HSLIDER","Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"NotApplicable":false,"MobileFirst":true,"SliderStartPositions":{"1":0.50047125353440147232930712561937980353832244873046875}},"QuestionDescription":"Please rate the extent to which you agree:\u00a0${lm:\/\/Field\/3}\u00a0really tries to help me.","Choices":{"1":{"Display":"&nbsp;"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":8,"Labels":{"3":{"Display":"Strongly disagree"},"7":{"Display":"Strongly agree"}},"QuestionID":"QID190","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID105","SecondaryAttribute":"Please write your Prolific ID Note that this should autofill with the correct ID \u00a0","TertiaryAttribute":null,"Payload":{"QuestionText":"Please write your Prolific ID<br>\n<em>Note that this should autofill with the correct ID<\/em><br>\n&nbsp;","DefaultChoices":{"TEXT":{"Text":"${e:\/\/Field\/workerId}"}},"DataExportTag":"prolific_id","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText","InputWidth":680,"InputHeight":29},"QuestionDescription":"Please write your Prolific ID Note that this should autofill with the correct ID \u00a0","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID105","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID281","SecondaryAttribute":"Sometimes I feel that I force my AI companions to show more feeling, more commitment.","TertiaryAttribute":null,"Payload":{"QuestionText":"Sometimes I feel that I force my AI companions to show more feeling, more commitment.<br>","DefaultChoices":false,"DataExportTag":"anxiety_10","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.5},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"Sometimes I feel that I force my AI companions to show more feeling, more commitment.","Choices":{"1":{"Display":"&nbsp;"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":3,"Labels":{"1":{"Display":"Strongly disagree"},"2":{"Display":"Strongly agree"}},"QuestionID":"QID281"}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID141","SecondaryAttribute":"Thank you for your participation in our study! Your participation is greatly appreciated.Purpose...","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for your participation in our study! Your participation is greatly appreciated.<br \/>\n<br \/>\n<strong>Purpose of the Study: <\/strong><br \/>\nFor the first time in history, recent AI language models are passing the Turing test, i.e., humans struggle to tell apart texts generated by these models from ones generated by humans. One exciting application of these advanced models are &#39;companion chatbot apps&#39;. These apps do not perform specific tasks per se, but are designed purely for social conversation, as you would normally do with a friend or romantic partner. The current project investigates how people perceive, interact and detect such chatbots, examining the psychological nature of these activities.<br \/>\n<br \/>\nAll data from this experiment are gathered for scientific purposes and will contribute to our eventual understanding of brain and visual function. These data may be published in scientific journals.<br \/>\n<br \/>\n<strong>More information:<\/strong><br \/>\nYou can find out more about the lab&rsquo;s research here: https:\/\/www.hbs.edu\/faculty\/Pages\/profile.aspx?facId=1326184&amp;view=publications. Although we do not know when we will publish a paper based on the research you participated in today, eventually it may be added to this webpage. Useful Contact Information: If you have any questions or concerns regarding this study, its purpose or procedures, or if you have a research-related problem, please feel free to contact the researcher(s), talk to the research team at ethicalintelligencelab@gmail.com Please provide your MTURK or Prolific ID.<br \/>\n<br \/>\nIf you wish to remove your data from the study now that you understand its nature, please reach out to the email above and provide your MTURK or Prolific ID. If you feel upset after having completed the study or find that some questions or aspects of the study triggered distress, talking with a qualified clinician may help. If you feel you would like assistance please contact the IMALIVE emotional crisis chatline at https:\/\/www.imalive.org\/online\/. You can also contact the suicide prevention hotline at https:\/\/suicidepreventionlifeline.org\/. In a serious emergency, remember that you can also call 911 for immediate assistance.<br \/>\n<br \/>\nOnce again, thank you for your participation in this study!","DefaultChoices":false,"DataExportTag":"debriefing_other","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for your participation in our study! Your participation is greatly appreciated.Purpose...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID141","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID142","SecondaryAttribute":"Thank you for your participation in our study! Your participation is greatly appreciated.Purpose...","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for your participation in our study! Your participation is greatly appreciated.<br \/>\n<br \/>\n<strong>Purpose of the Study: <\/strong><br \/>\nFor the first time in history, recent AI language models are passing the Turing test, i.e., humans struggle to tell apart texts generated by these models from ones generated by humans. One exciting application of these advanced models are &#39;companion chatbot apps&#39;. These apps do not perform specific tasks per se, but are designed purely for social conversation, as you would normally do with a friend or romantic partner. The current project investigates how people perceive, interact and detect such chatbots, examining the psychological nature of these activities.<br \/>\n<br \/>\nEarlier in the consent form we informed you that the purpose of the study was to study social interaction. Depending on the condition you were in, <u><strong>we may have deceived you on the identity of the agent you chatted with.<\/strong><\/u> We did this to ensure that your reactions were natural and not influenced by your existing conceptions of chatbots, and to understand the stigma that people hold for chatbots. Although we would have preferred to disclose all details of the study upfront, we hope you understand the reason that we withheld this information until the end.<br \/>\n<br \/>\n<strong>Your assigned condition was: human. Thus we informed you that you interacted with a human, but you actually interacted with a chatbot.<\/strong><br \/>\n<br \/>\nAll data from this experiment are gathered for scientific purposes and will contribute to our eventual understanding of brain and visual function. These data may be published in scientific journals.<br \/>\n<br \/>\n<strong>More information:<\/strong><br \/>\nYou can find out more about the lab&rsquo;s research here: https:\/\/www.hbs.edu\/faculty\/Pages\/profile.aspx?facId=1326184&amp;view=publications. Although we do not know when we will publish a paper based on the research you participated in today, eventually it may be added to this webpage. Useful Contact Information: If you have any questions or concerns regarding this study, its purpose or procedures, or if you have a research-related problem, please feel free to contact the researcher(s), talk to the research team at ethicalintelligencelab@gmail.com Please provide your MTURK or Prolific ID. If you wish to remove your data from the study now that you understand its nature, please reach out to the email above and provide your MTURK or Prolific ID.<br \/>\n<br \/>\nIf you feel upset after having completed the study or find that some questions or aspects of the study triggered distress, talking with a qualified clinician may help. If you feel you would like assistance please contact the IMALIVE emotional crisis chatline at https:\/\/www.imalive.org\/online\/. You can also contact the suicide prevention hotline at https:\/\/suicidepreventionlifeline.org\/. In a serious emergency, remember that you can also call 911 for immediate assistance.<br \/>\n<br \/>\nOnce again, thank you for your participation in this study!","DefaultChoices":false,"DataExportTag":"debriefing_deception","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for your participation in our study! Your participation is greatly appreciated.Purpose...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID142","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID224","SecondaryAttribute":"The change in my AI companion would negatively affect my mental health.","TertiaryAttribute":null,"Payload":{"QuestionText":"The change in my AI companion would negatively affect my mental health.","DefaultChoices":false,"DataExportTag":"mental_health","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.5},"NotApplicable":false,"Mobi