ponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":3,"Labels":{"1":{"Display":"Strongly disagree"},"2":{"Display":"Strongly agree"}},"QuestionID":"QID279"}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID308","SecondaryAttribute":"My desire to be very close sometimes scares people away.","TertiaryAttribute":null,"Payload":{"QuestionText":"My desire to be very close sometimes scares people away.","DefaultChoices":false,"DataExportTag":"closeness_scare","QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.5},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"My desire to be very close sometimes scares people away.","Choices":{"1":{"Display":"&nbsp;"}},"ChoiceOrder":["1"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":3,"Labels":{"1":{"Display":"Strongly disagree"},"2":{"Display":"Strongly agree"}},"QuestionID":"QID308"}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID264","SecondaryAttribute":"My Replika makes me feel comfortable, as if I am with friends.","TertiaryAttribute":null,"Payload":{"QuestionText":"My Replika makes me feel comfortable, as if I am with friends.","DefaultChoices":false,"QuestionType":"Slider","Selector":"HSLIDER","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"SnapToGrid":false,"NumDecimals":"0","ShowValue":true,"CustomStart":true,"SliderStartPositions":{"1":0.5},"NotApplicable":false,"MobileFirst":true},"QuestionDescription":"My Replika makes me feel comfortable, as if I am with friends."