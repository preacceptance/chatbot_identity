imaryAttribute":"QID31","SecondaryAttribute":"What color is grass? The fresh, uncut grass, not leaves or hay. Please make sure to select purple...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>What color is grass?<\/strong><br><br>The fresh, uncut grass, not leaves or hay. Please make sure to select purple, so that we know you're paying attention.","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What color is grass? The fresh, uncut grass, not leaves or hay. Please make sure to select purple...","Choices":{"1":{"Display":"Green"},"2":{"Display":"Purple"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionText_Unsafe":"<strong>What color is grass?<\/strong><br>\n<br>\nThe fresh, uncut grass, not leaves or hay. Please make sure to select purple, so that we know you're paying attention.","DataExportTag":"att_2","QuestionID":"QID31","RecodeValues":{"1":"1","2":"2"}}},{"SurveyID":"SV_5AnNYagjHZGw4oS","Element":"SQ","PrimaryAttribute":"QID15","SecondaryAttribute":"What is the highest level of education you have completed?","TertiaryAttribute":null,"Payload":{"QuestionText":"<span style=\"font-weight: bolder;\">What is the highest level of education you have completed?<\/span>","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"What is the highest level of education you have completed?","Choices":{"1":{"Display":"High School or Equivalent"},"2":{"Display":"Vocational\/Technical School (2 year)"},"3":{"Display":"Some College"},"4":{"Display":"College Graduate (4 year)"},"5":{"Display":"Masters Degree (MS)"},"6":{"Display":"Doctoral Degree (PhD)"},"7":{"Display":"Professional Degree (MD, JD, etc.)"},"8":{"Display":"Other (please